# Bu dosyayı .env olarak kopyala ve gerçek anahtarlarını yaz.
# Google AI Studio'dan API key al: https://aistudio.google.com/apikey
# Gemini File URI'si katalog_yukleyici.py çalıştırılınca terminalde yazdırılır.
GEMINI_API_KEY=buraya_kendi_anahtarinizi_yazin
GEMINI_FILE_URI=https://generativelanguage.googleapis.com/v1beta/files/BURAYA_FILE_ID
